{
  "version": 2,
  "name": "influencore-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://backendnew-lz1u.onrender.com",
    "VITE_APP_ENV": "production"
  }
}
