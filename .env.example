# Frontend Environment Variables
# Copy this file to .env.local for development and .env.production for production

# API Configuration - Update this to your actual backend URL
# For development, use your local backend URL
VITE_API_URL=http://localhost:3000

# For production, use your deployed backend URL
# VITE_API_URL=https://backendnew-lz1u.onrender.com

# Development Settings (only for local development)
VITE_DEV_MODE=false

# Analytics (Optional)
VITE_GA_TRACKING_ID=your-ga-tracking-id

# Social Login (Optional - for future implementation)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GITHUB_CLIENT_ID=your-github-client-id

# Feature Flags (Optional)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SOCIAL_LOGIN=false

# App Environment
VITE_APP_ENV=development